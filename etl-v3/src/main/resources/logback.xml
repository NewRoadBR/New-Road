<?xml version="1.0" encoding="UTF-8"?>
<!--
    logback.xml — Configuração do Logback para saída no console.
    O log persistente (em banco) é gerenciado pelo ServicoLog.
-->
<configuration>

    <!-- Appender para o console com padrão colorido -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Nível raiz: INFO (DEBUG disponível para desenvolvimento) -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
